# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose "anthropic", "openai", "openrouter", "github", or "ollama"
LLM_PROVIDER=openrouter

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-haiku-20240307

# OpenAI
OPENAI_API_KEY=sk-abcdef1234567890abcdef1234567890abcdef12
OPENAI_MODEL=gpt-3.5-turbo

# OpenRouter (unified API for 200+ models - RECOMMENDED for production)
# Get your free API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_MODEL=your-model-here

# LLM generation parameters
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# ── Embeddings ───────────────────────────────────────────────────────────────
# "local"  → sentence-transformers/all-MiniLM-L6-v2 (no extra API key)
# "openai" → OpenAI text-embedding-3-small (requires OPENAI_API_KEY)
EMBEDDING_BACKEND=local

# ── RAG / ChromaDB ────────────────────────────────────────────────────────────
CHROMA_COLLECTION=tspec_telecom
CHUNK_SIZE=400
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=4
TOP_K_SUMMARIZE=6

# ── Dataset ───────────────────────────────────────────────────────────────────
# Number of records to pull from rasoul-nikbakht/TSpec-LLM for local dev
TSPEC_SAMPLE_SIZE=200

# ── Validation ────────────────────────────────────────────────────────────────
# Answers with confidence below this value are flagged for human approval
CONFIDENCE_THRESHOLD=0.6

# ── FastAPI Server ────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
