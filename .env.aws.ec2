# AWS EC2 environment configuration for AI Telecom Assistant
# Copy this file to .env on the EC2 instance before starting the app.

# Core app settings
LLM_PROVIDER=openrouter
API_HOST=0.0.0.0
API_PORT=8000

# OpenRouter configuration
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_MODEL=openai/gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# Embeddings
EMBEDDING_BACKEND=local

# RAG / ChromaDB
CHROMA_COLLECTION=tspec_telecom
CHUNK_SIZE=400
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=4
TOP_K_SUMMARIZE=6

# Optional periodic ingestion refresh on EC2
RAG_REFRESH_ENABLED=true
RAG_REFRESH_INTERVAL_MINUTES=60
RAG_REFRESH_ON_STARTUP=true

# Validation threshold
CONFIDENCE_THRESHOLD=0.6

# Optional OpenAI config (leave blank if not used)
OPENAI_API_KEY=<>
OPENAI_MODEL=gpt-4.0
