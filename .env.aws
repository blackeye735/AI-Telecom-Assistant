# AWS Deployment Configuration for App Runner
# This file is used by AWS App Runner to configure environment variables

# LLM Configuration
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_MODEL=your-model-here
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# RAG Configuration
EMBEDDING_BACKEND=local
CHROMA_COLLECTION=tspec_telecom
CHUNK_SIZE=400
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=4
TOP_K_SUMMARIZE=6
CONFIDENCE_THRESHOLD=0.6

# Dataset Configuration
TSPEC_SAMPLE_SIZE=200

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# SSL Configuration (set to false for AWS)
SSL_VERIFY=true
